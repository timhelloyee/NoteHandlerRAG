# Copy to .env and fill in real values. Never commit .env.

# Gemini API keys (two keys to spread the usage limit; the app fails over on quota errors)
GEMINI_API_KEY_PRIMARY=your-gemini-key-1
GEMINI_API_KEY_SECONDARY=your-gemini-key-2

# Hugging Face token. Write access enables persisting vectorstores to the private
# Dataset below; a read token still restores existing data; omit for ephemeral-only.
HF_TOKEN=hf_xxx

# Optional overrides
#VECTORSTORE_DATASET=timhelloyee/notehandler-store
#VECTORSTORE_ROOT=./vectorstores
#ALLOWED_ORIGINS=https://timhelloyee.github.io,http://localhost:8000
